# Plane Conductor — runtime settings (host-wide).
#
# Per-workspace settings (Plane creds, project, prompts dir, agents, secrets)
# live in conductor.d/<slug>.yaml — see examples/conductor.d/*.yaml.
#
# This file holds only the knobs that apply to the whole orchestrator process.

# --- Webhook server -----------------------------------------------------------
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000

# --- Where workspace configs live --------------------------------------------
# Directory of per-workspace YAMLs (one file per workspace, named <slug>.yaml).
CONDUCTOR_DIR=/etc/plane-conductor/conductor.d

# --- Agent invocation ---------------------------------------------------------
# Path to the `claude` CLI binary. Use absolute path if it isn't on PATH for
# the service user. Each workspace's prompts_dir + agent_working_dir is set
# in that workspace's YAML.
CLAUDE_BINARY=claude

# --- Operations ---------------------------------------------------------------
LOG_DIR=./logs
LOG_LEVEL=INFO
# LOG_FORMAT: pretty | json
LOG_FORMAT=pretty
# Host-wide cap (counts agents across ALL workspaces).
MAX_CONCURRENT_SESSIONS=5
SESSION_TIMEOUT_SECONDS=3600
# Seconds to wait for in-flight agents on SIGTERM. After this, all subprocess
# groups are SIGKILL'd. Keep below systemd's TimeoutStopSec (default 90s).
SHUTDOWN_GRACE_SECONDS=30
